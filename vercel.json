{
  "version": 2,
  "builds": [
    {
      "src": "template/**",
      "use": "@vercel/static"
    },
    {
      "src": "src/vercel.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/template/(.*)",
      "dest": "/template/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "src/vercel.js"
    }
  ]
}